{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "lumelf",
      "camelcase": "lumelf",
      "title": "lumelf",
      "scope": "source.lumelf",
      "file-types": ["lmf"],
      "injection-regex": "^lumelf$",
      "class-name": "TreeSitterlumelf",
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "tags": "queries/tags.scm",
      "brackets": "queries/brackets.scm",
      "first-line-regex": "^#!.*\\b(lumelf)\\b.*$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "lfrc via lumesh",
    "authors": [
      {
        "name": "santo",
        "url": "https://lumesh.codeberg.page/"
      }
    ],
    "links": {
      "repository": "https://codeberg.org/santo/lumelf"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": true,
    "python": false,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
